<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>AI_M_OS.SystemMonitor</RootNamespace>
    <AssemblyName>ai-m-os-sysmon</AssemblyName>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="GirCore.Gtk-4.0" Version="0.5.0" />
    <PackageReference Include="GirCore.Adw-1"   Version="0.5.0" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="themes/**">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
</Project>
